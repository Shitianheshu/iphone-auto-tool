{
  "name": "iphone-auto-purchase",
  "version": "2.0.0",
  "description": "Optimized iPhone auto-purchase automation with advanced error handling and performance monitoring",
  "main": "main.js",
  "scripts": {
    "start": "cross-env SPEED_MODE=1 SPEED_FACTOR=0.02 DEBUG_SESSIONS=1 electron .",
    "dev": "electron . --dev",
    "build:all": "electron-builder -mwl",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "test": "jest",
    "lint": "eslint .",
    "logs": "tail -f logs/combined.log",
    "webhook": "node otp-webhook-server.js",
    "start:full": "concurrently \"npm run webhook\" \"npm start\""
  },
  "keywords": [
    "iphone",
    "automation",
    "puppeteer",
    "electron",
    "apple",
    "purchase"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "async-retry": "^1.3.3",
    "axios": "^1.6.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "get-port": "^7.1.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^128.0.0",
    "puppeteer-core": "^21.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "puppeteer-in-electron": "^3.0.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.54.0",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.Tech.iphone-auto-purchase",
    "productName": "iPhone Auto Purchase",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!logs/**/*"
    ],
    "extraResources": [
      {
        "from": "service-account.json",
        "to": "service-account.json"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  }
}
